# ──────────────────────────────────────────────────────────────────────────────
# AIXYNZ Cortex — Environment Variables
# Copy this to .env and fill in real values before deploying.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Mode ─────────────────────────────────────────────────────────────────────
# Set to "true" to use Redis/RQ for background scans.
# In demo mode (no serviceAccountKey.json), this can remain false.
USE_RQ=false

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Firebase Backend (Admin SDK) ─────────────────────────────────────────────
# Paste the full service account JSON as a single-line string for Render deploys.
# FIREBASE_CREDENTIALS={"type":"service_account","project_id":"..."}

# ── Firebase Frontend (Vite) ──────────────────────────────────────────────────
# Create frontend/.env with these values for local dev.
# On Render, add them as Environment Variables in the dashboard.
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── AWS ──────────────────────────────────────────────────────────────────────
# AWS credentials (boto3 default chain — env vars or IAM role preferred)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# ── GitHub ───────────────────────────────────────────────────────────────────
# GitHub personal access token or GitHub App token for repo scanning
# GITHUB_TOKEN=

# ── Jira ─────────────────────────────────────────────────────────────────────
# JIRA_URL=https://yourorg.atlassian.net
# JIRA_USERNAME=
# JIRA_API_TOKEN=
# JIRA_PROJECT_KEY=

# ── Slack ────────────────────────────────────────────────────────────────────
# SLACK_WEBHOOK_URL=

# ── Groq (AI Analysis) ───────────────────────────────────────────────────────
# GROQ_API_KEY=

# ── API Settings ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
SCAN_INTERVAL_SECONDS=86400
FRONTEND_ORIGIN=http://localhost:5173
